NEXT_PUBLIC_EDGAR_USER_AGENT="Your Name contact@yourdomain.com"
VITE_CLERK_PUBLISHABLE_KEY="your-clerk-publishable-key"
# Optional localhost fallback for SEC full-text search when efts.sec.gov blocks local dev requests
VITE_SEC_PROXY_FALLBACK_BASE="https://vara-ai-app.vercel.app"
ANTHROPIC_API_KEY="your-anthropic-api-key"
ANTHROPIC_MODEL="claude-sonnet-4-20250514"


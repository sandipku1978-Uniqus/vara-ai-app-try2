# VITE_USE_ELASTICSEARCH="true"
# ELASTICSEARCH_URL="https://your-deployment.es.us-east-1.aws.elastic.cloud:443"
# ELASTICSEARCH_API_KEY="your-elastic-api-key"
# ELASTICSEARCH_INDEX="sec-filings"

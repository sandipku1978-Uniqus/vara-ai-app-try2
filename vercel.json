{
  "routes": [
    { "src": "^/sec-proxy/?$", "dest": "/api/sec-proxy.js" },
    { "src": "^/sec-proxy/(.*)$", "dest": "/api/sec-proxy.js?path=$1" },
    { "src": "^/sec-data/?$", "dest": "/api/sec-data.js" },
    { "src": "^/sec-data/(.*)$", "dest": "/api/sec-data.js?path=$1" },
    { "src": "^/sec-efts/?$", "dest": "/api/sec-efts.js" },
    { "src": "^/sec-efts/(.*)$", "dest": "/api/sec-efts.js?path=$1" },
    { "src": "^/(ix|ixviewer|Archives|include|files|cdata|js|css|images)/(.*)$", "dest": "/api/sec-proxy.js?path=$1/$2" },
    { "handle": "filesystem" },
    { "src": "/.*", "dest": "/" }
  ]
}
